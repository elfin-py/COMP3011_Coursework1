# Application
PORT=3000
NODE_ENV=development

# Auth
# Set strong random secrets before starting the API
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRES=900s
JWT_REFRESH_EXPIRES=7d

# Database
DATABASE_URL=postgresql://cfx:cfxpass@localhost:5432/cfx?schema=public

# Prisma
PRISMA_LOG_LEVEL=info

# Optional AI chat extraction (Hugging Face)
HF_TOKEN=
HF_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
